# ============ 飞书应用配置 ============
# 在 https://open.feishu.cn/app 创建自建应用获取

FEISHU_APP_ID=cli_xxxxx
FEISHU_APP_SECRET=xxxxx

# 事件订阅配置（在应用后台「事件订阅」页面获取）
FEISHU_ENCRYPT_KEY=xxxxx
FEISHU_VERIFICATION_TOKEN=xxxxx

# ============ 飞书目标配置 ============

# 结果推送的群 Chat ID（通过 API 或群设置获取）
FEISHU_GROUP_CHAT_ID=oc_xxxxx

# 多维表格配置（从表格 URL 获取）
# URL 格式: https://xxx.feishu.cn/base/{app_token}?table={table_id}
FEISHU_BITABLE_APP_TOKEN=xxxxx
FEISHU_BITABLE_TABLE_ID=tblxxxxx

# ============ Gemini API ============

GEMINI_API_KEY=xxxxx

# ============ 服务器配置 ============

PORT=3000
TEMP_DIR=/tmp/video-analyzer

# ============ 可选配置 ============

# 日志级别
LOG_LEVEL=info

# 并发下载数
MAX_CONCURRENT_DOWNLOADS=3
